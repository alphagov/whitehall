<div class="app-view-edit-edition__appointment-fields">
  <% cache_if ministerial_role_appointments.selected_ids.empty?, "#{ministerial_role_appointments.template_cache_digest}" do %>
    <%= render "govuk_publishing_components/components/select_with_search", {
      id: "edition_role_appointment_ids",
      name: "edition[role_appointment_ids][]",
      include_blank: true,
      label: "Ministers",
      heading_size: "m",
      options: ministerial_role_appointments.scoped_appointments.map do |appointment|
        {
          text: role_appointment_option_label(appointment),
          value: appointment.id,
          selected: ministerial_role_appointments.selected_ids.include?(appointment.id),
        }
      end,
      multiple: true,
    } %>
  <% end %>
</div>
