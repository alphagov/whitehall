{
  "key": "topical_event",
  "title": "Topical event",
  "description": "Editionable topical events",
  "forms": {
    "documents": {
      "fields": {
        "body": {
          "title": "Body",
          "description": "The main content of the page",
          "required": true,
          "block": "govspeak",
          "attribute_path": ["block_content", "body"],
          "translatable": true
        },
        "lead_organisations": {
          "title": "Lead organisations",
          "required": true,
          "block": "ordered_select_with_search_tagging",
          "container": "organisations",
          "attribute_path": ["lead_organisation_ids"],
          "size": 4,
          "translatable": false
        },
        "supporting_organisations": {
          "title": "Supporting organisations",
          "block": "select_with_search_tagging",
          "container": "organisations",
          "attribute_path": ["supporting_organisation_ids"],
          "translatable": false
        }
      }
    },
    "social_media_accounts": {
      "dynamic": true,
      "label": "Social media accounts",
      "fields": {
        "social_media_links": {
          "title": "Social media accounts",
          "block": "default_array",
          "attribute_path": ["block_content", "social_media_links"],
          "translatable": true,
          "fields": {
            "social_media_service_name": {
              "title": "Channel",
              "block": "default_select",
              "attribute_path": ["social_media_service_name"],
              "blank_option_label": "Select channel",
              "translatable": true,
              "options": [
                {
                  "label": "Twitter",
                  "value": "Twitter"
                },
                {
                  "label": "Facebook",
                  "value": "Facebook"
                },
                {
                  "label": "YouTube",
                  "value": "YouTube"
                },
                {
                  "label": "Flickr",
                  "value": "Flickr"
                },
                {
                  "label": "Blog",
                  "value": "Blog"
                },
                {
                  "label": "Pinterest",
                  "value": "Pinterest"
                },
                {
                  "label": "LinkedIn",
                  "value": "LinkedIn"
                },
                {
                  "label": "Google Plus",
                  "value": "Google Plus"
                },
                {
                  "label": "Foursquare",
                  "value": "Foursquare"
                },
                {
                  "label": "Email",
                  "value": "Email"
                },
                {
                  "label": "Instagram",
                  "value": "Instagram"
                },
                {
                  "label": "Bluesky",
                  "value": "Bluesky"
                },
                {
                  "label": "Threads",
                  "value": "Threads"
                },
                {
                  "label": "Other",
                  "value": "Other"
                }
              ]
            },
            "url": {
              "title": "URL",
              "block": "default_string",
              "attribute_path": ["url"],
              "translatable": true
            }
          }
        }
      }
    }
  },
  "schema": {
    "attributes": {
      "body": {
        "type": "string"
      },
      "social_media_links": {
        "type": "array",
        "attributes": {
          "social_media_service_name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      }
    },
    "validations": {
      "presence": {
        "attributes": ["body"]
      },
      "length": {
        "attributes": ["body"],
        "maximum": 16777215
      },
      "safe_html": {
        "attributes": ["body"]
      },
      "no_footnotes_allowed": {
        "attributes": ["body"]
      },
      "embedded_contacts_exist": {
        "attributes": ["body"],
        "on": "publish"
      },
      "social_media_links": {
        "attributes": ["social_media_links"],
        "fields": {
          "service_field": "social_media_service_name",
          "url_field": "url"
        }
      }
    }
  },
  "presenters": {
    "publishing_api": {
      "details": {
        "body": "govspeak",
        "social_media_links": "social_media_links"
      },
      "links": [
        "organisations"
      ]
    }
  },
  "settings": {
    "base_path_prefix": "/government/topical-events",
    "publishing_api_schema_name": "topical_event",
    "publishing_api_document_type": "topical_event",
    "rendering_app": "frontend",
    "images": {
      "enabled": true,
      "usages": {
        "header": {
          "label": "header image",
          "kinds": ["topical_event_header"],
          "multiple": false,
          "caption_enabled": false
        },
        "logo": {
          "label": "event logo",
          "kinds": ["topical_event_logo"],
          "multiple": false,
          "caption_enabled": false
        }
      }
    },
    "send_change_history": false,
    "file_attachments_enabled": false,
    "features_enabled": true,
    "organisations": null,
    "backdating_enabled": false,
    "history_mode_enabled": false,
    "translations_enabled": false
  }
}
